# ==================================================
# 🌐 DOMAIN CONFIGURATION
# ==================================================
BACKEND_HOST=0.0.0.0
FRONTEND_URL=http://localhost:8080

# Порты сервисов
AUTH_PORT=8000
POSTS_PORT=3000
PAYMENTS_PORT=9000
PAYMENTS_TEST_MODE=true
MAIN_PORT=8080
CHAT_PORT=4000
IMEI_PORT=5001

# Публичные URL сервисов
AUTH_SERVICE_URL=http://localhost:8000
POSTS_SERVICE_URL=http://localhost:3000
PAYMENTS_SERVICE_URL=http://localhost:9000

# ==================================================
# � DELIVERY CONFIGURATION
# ==================================================
# Стоимость доставки в евро (€)
DELIVERY_COST_PICKUP=0
DELIVERY_COST_DPD=2.99
DELIVERY_COST_OMNIVA=1.99

# DPD integration modes (delivery-service)
# true + true  => full local simulation for DPD
# false + true => proxy DPD flow to Omniva TEST endpoints
# false + false => real DPD API requests
DPD_TEST_MODE=true
DPD_INNER_SYSTEM_SIMULATION=true
DPD_REAL_API_BASE_URL=https://eserviss.dpd.lv/api/v1
DPD_TEST_API_BASE_URL=https://sandbox-eserviss.dpd.lv/api/v1
OMNIVA_TEST_API_BASE_URL=https://test-omx.omniva.eu/api/v01/omx

# ==================================================
# �🔐 SECURITY CONFIGURATION
# ==================================================
# ВАЖНО: Сгенерируйте надежный ключ для продакшена!
# python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-here
TOKEN_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

SESSION_SECRET=your-session-secret-here

# ==================================================
# 🔑 GOOGLE OAUTH CONFIGURATION
# ==================================================
# Получить: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-secret

# ==================================================
# ☁️ CLOUDFLARE CONFIGURATION
# ==================================================
# Получить: https://dash.cloudflare.com/
CF_ACCOUNT_ID=your-cloudflare-account-id
CF_ACCOUNT_HASH=your-cloudflare-account-hash
CF_R2_ACCESS_KEY_ID=your-r2-access-key
CF_R2_SECRET_ACCESS_KEY=your-r2-secret-key
CF_API_TOKEN=your-cloudflare-api-token
CF_IMAGE_DELIVERY_URL=https://imagedelivery.net

# ==================================================
# 📱 IMEI CHECKER API CONFIGURATION
# ==================================================
# Production режим
USE_TEST_MODE=true

# IMEI.info API (Primary)
IMEI_INFO_API_KEY=your_imei_info_api_key_here

# IMEI.org API (Fallback) 
IMEI_ORG_API_KEY=your_numberingplans_token_here

# ==================================================
# 💳 STRIPE PAYMENTS CONFIGURATION
# ==================================================
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ==================================================
# 📊 GOOGLE ADSENSE (опционально)
# ==================================================
# GOOGLE_ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXX
# GOOGLE_ADSENSE_ENABLED=false

# ==================================================
# 🗄️ DATABASE CONFIGURATION
# ==================================================
USE_POSTGRES=true

POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=lais_marketplace
