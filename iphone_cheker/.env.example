# IMEI Checker Service Environment Variables

# === Mode ===
# Test mode uses mock data (free, no API keys needed)
# Production mode uses real APIs (requires API keys and credits)
USE_TEST_MODE=true

# === Database ===
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/lais_marketplace

# === API Keys (for production mode) ===
# Get these from respective services:
# - IMEI.info: https://dash.imei.info (Primary, ~$0.05-0.10 per check)
# - IMEI.org: https://www.imei.org/api-connect/ (Custom API, Fallback, ~$0.05-0.15 per check)
#   Format for IMEI.org: just API key (Custom API, not Dhru)

IMEI_INFO_API_KEY=your_imei_info_api_key_here
IMEI_ORG_API_KEY=your_imei_org_api_key_here

# === Cache Settings ===
# How long to cache IMEI check results (in days)
IMEI_CACHE_TTL_DAYS=7

# === Mode Settings ===
# true = use mock data, false = use real APIs
USE_TEST_MODE=true

# === Timeout Settings ===
# Timeout for external API calls (in seconds)
API_TIMEOUT_SECONDS=10

# === Security ===
SECRET_KEY=your-secret-key-here
TOKEN_ALGORITHM=HS256

# === Service Configuration ===
PORT=5002
BACKEND_HOST=0.0.0.0
